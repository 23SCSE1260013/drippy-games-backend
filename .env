# Copy this to .env and fill in your values
PORT=4000
MONGO_URI=mongodb://localhost:27017/drippygames
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d
FRONTEND_URL=http://localhost:3000

